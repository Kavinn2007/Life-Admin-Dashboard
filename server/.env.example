# Server Port
PORT=5000

# Prisma Database URL (e.g. SQLite "file:./dev.db" or PostgreSQL connection string)
DATABASE_URL="file:./dev.db"

# JWT Auth Secret
JWT_SECRET="generate_a_long_random_string_here"

# Dynamic uploads directory (optional, defaults to local folder)
UPLOAD_DIR=""

# Allowed CORS Frontend URL (optional, defaults to * / localhost in dev)
FRONTEND_URL=""

# Optional Cloudinary Storage Configuration
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional Gemini AI API Key
GEMINI_API_KEY=""
